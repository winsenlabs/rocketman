{
  "name": "@winsendotai/rocketman",
  "version": "0.1.3",
  "description": "Idea to production on autopilot. An in-repo HTML project hub + a Claude skill track for responsible token-maxing. By Winsen Labs.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "rocketman": "bin/rocketman.mjs"
  },
  "scripts": {
    "build": "node engine/build.mjs",
    "check": "node engine/build.mjs --check",
    "doctor": "node bin/rocketman.mjs doctor",
    "smoke": "node engine/smoke.mjs",
    "test": "node engine/build.mjs --check && node bin/rocketman.mjs doctor && node engine/smoke.mjs"
  },
  "files": [
    "engine",
    "templates",
    "bin",
    ".claude",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "project-management",
    "product-management",
    "prd",
    "kanban",
    "ai-agents",
    "claude",
    "claude-code",
    "local-first",
    "html",
    "single-file"
  ],
  "author": "Winsen Labs",
  "license": "MIT",
  "homepage": "https://github.com/winsenlabs/rocketman#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/winsenlabs/rocketman.git"
  },
  "bugs": {
    "url": "https://github.com/winsenlabs/rocketman/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
